# Set to true to force all API tools to use mock data (offline dev/demo mode)
USE_MOCK=false

# AirNow API key — required
# Register at: https://docs.airnowapi.org/account/request/
AIRNOW_API_KEY=your_key_here

# USGS Water API key — optional but recommended for higher rate limits
# Register at: https://api.waterdata.usgs.gov/signup/
USGS_API_KEY=your_key_here
